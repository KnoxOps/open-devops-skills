{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Observation Report",
  "description": "Final observation report per resource (Phase D output) - primary deliverable to Phase 5",
  "type": "object",
  "properties": {
    "observation_id": {
      "type": "string",
      "pattern": "^obs-",
      "description": "Unique observation identifier (obs-{uuid})"
    },
    "resource_id": {
      "type": "string"
    },
    "resource_type": {
      "type": "string",
      "enum": [
        "compute",
        "storage",
        "network",
        "database",
        "cache",
        "k8s_workload",
        "k8s_service",
        "k8s_orphan",
        "domain"
      ]
    },
    "isolation_executed_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when isolation was actually executed"
    },
    "isolation_method": {
      "type": "string",
      "description": "Method used to isolate the resource"
    },
    "observation_start": {
      "type": "string",
      "format": "date-time"
    },
    "observation_end": {
      "type": "string",
      "format": "date-time"
    },
    "observation_period_days": {
      "type": "integer",
      "minimum": 1
    },
    "observation_result": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "uncertain"
      ],
      "description": "Final observation verdict: passed=zombie confirmed, failed=rollback occurred, uncertain=manual review needed"
    },
    "metrics_summary": {
      "type": "object",
      "properties": {
        "alert_count": {
          "type": "integer",
          "minimum": 0
        },
        "complaint_count": {
          "type": "integer",
          "minimum": 0
        },
        "anomaly_dates": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "date"
          },
          "description": "Sorted unique dates with alerts/complaints"
        },
        "max_error_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "max_latency_ms": {
          "type": "number"
        },
        "max_cpu_percent": {
          "type": "number"
        }
      },
      "required": [
        "alert_count",
        "complaint_count",
        "anomaly_dates",
        "max_error_rate"
      ]
    },
    "rollback_status": {
      "type": "string",
      "enum": [
        "not_needed",
        "triggered",
        "completed",
        "failed"
      ],
      "description": "Status of rollback operation"
    },
    "rollback_executed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time",
      "description": "Timestamp when rollback was executed (null if not triggered)"
    },
    "attribution": {
      "type": [
        "object",
        "null"
      ],
      "description": "3D anomaly attribution results (present if failed)",
      "properties": {
        "overall_attribution": {
          "type": "string",
          "enum": [
            "CONFIRMED",
            "UNCERTAIN",
            "DISMISS"
          ]
        },
        "anomalies_analyzed": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "anomaly_type": {
                "type": "string"
              },
              "anomaly_signal": {
                "type": "string"
              },
              "temporal_score": {
                "type": "number"
              },
              "topological_score": {
                "type": "number"
              },
              "directional_score": {
                "type": "number"
              },
              "attribution_result": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "failure_reason": {
      "type": [
        "string",
        "null"
      ],
      "description": "Reason for failure if observation_result != passed"
    },
    "notes": {
      "type": "string",
      "description": "Additional notes and context"
    }
  },
  "required": [
    "observation_id",
    "resource_id",
    "resource_type",
    "isolation_executed_at",
    "isolation_method",
    "observation_start",
    "observation_end",
    "observation_period_days",
    "observation_result",
    "metrics_summary",
    "rollback_status"
  ]
}
