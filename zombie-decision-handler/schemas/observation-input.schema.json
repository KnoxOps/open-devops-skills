{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Observation Report Input",
  "description": "Phase 2 observation report for a single resource. Used as input to the decision handler merge step.",
  "type": "object",
  "required": ["observation_id", "resource_id", "observation_result"],
  "properties": {
    "observation_id": { "type": "string" },
    "resource_id": { "type": "string" },
    "resource_type": { "type": "string" },
    "isolation_executed_at": { "type": "string", "format": "date-time" },
    "isolation_method": { "type": "string" },
    "observation_start": { "type": "string", "format": "date-time" },
    "observation_end": { "type": "string", "format": "date-time" },
    "observation_period_days": { "type": "integer" },
    "observation_result": {
      "type": "string",
      "enum": ["passed", "failed", "uncertain"]
    },
    "alert_count": { "type": "integer" },
    "complaint_count": { "type": "integer" },
    "anomaly_events": { "type": "array" },
    "rollback_triggered": { "type": "boolean" },
    "rollback_status": { "type": "string" },
    "metrics_summary": { "type": "object" },
    "failure_reason": { "type": "string" },
    "notes": { "type": "string" }
  }
}
