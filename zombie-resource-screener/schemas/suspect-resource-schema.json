{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Single Resource Zombie Suspect Assessment",
  "description": "Per-resource output for a single candidate in Phase 1 Suspect layer",
  "type": "object",
  "required": [
    "assessed_at",
    "resource_id",
    "resource_type",
    "entity_type",
    "environment",
    "creation_time",
    "estimated_monthly_cost",
    "suspect_level",
    "zombie_score",
    "priority",
    "owner_status",
    "owner_detail",
    "investigation_brief",
    "blast_radius",
    "evidence",
    "protection_rules_checked",
    "data_quality",
    "risk_factors",
    "suggested_verification"
  ],
  "properties": {
    "assessed_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 assessment timestamp"
    },
    "resource_id": {
      "type": "string",
      "description": "Unique resource identifier"
    },
    "resource_type": {
      "type": "string",
      "enum": [
        "compute",
        "storage",
        "network",
        "database",
        "cache",
        "k8s_workload",
        "k8s_service",
        "k8s_orphan",
        "domain"
      ]
    },
    "entity_type": {
      "type": "string",
      "description": "Semantic network entity type (e.g., CloudVM, CloudRDS, K8sWorkload)"
    },
    "environment": {
      "type": "string",
      "enum": ["production", "staging", "dev", "unknown"],
      "description": "Environment tag"
    },
    "creation_time": {
      "type": "string",
      "format": "date-time",
      "description": "Resource creation timestamp"
    },
    "estimated_monthly_cost": {
      "type": "number",
      "minimum": 0,
      "description": "Estimated monthly cost in USD"
    },
    "suspect_level": {
      "type": "string",
      "enum": ["high", "medium", "low"],
      "description": "Zombie suspicion level"
    },
    "zombie_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Weighted zombie suspicion score (deterministic calculation, never LLM output)"
    },
    "priority": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Priority ranking score for investigation"
    },
    "owner_status": {
      "type": "string",
      "enum": ["active_owner", "orphaned", "untagged", "shared"],
      "description": "Ownership status"
    },
    "owner_detail": {
      "type": "string",
      "description": "Specific owner name, team, or contact information"
    },
    "investigation_brief": {
      "type": "string",
      "minLength": 15,
      "maxLength": 300,
      "description": "2-3 sentence summary covering owner status, activity findings, zombie chain, risk factors"
    },
    "blast_radius": {
      "type": "object",
      "required": ["summary", "depends_on", "dependencies"],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 10,
          "description": "Natural language blast radius analysis (NO numeric scores)"
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of resources this candidate depends on"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of resources that depend on this candidate"
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["dimension", "marker", "finding"],
        "properties": {
          "dimension": {
            "type": "string",
            "description": "Scoring dimension name (e.g., cpu_memory, connections)"
          },
          "marker": {
            "type": "string",
            "enum": ["[CONFIRMED]", "[SUPPORTED]", "[INFERRED]", "[UNKNOWN]"],
            "description": "Confidence level of this evidence"
          },
          "finding": {
            "type": "string",
            "description": "Specific evidence text"
          },
          "metric_value": {
            "description": "Associated metric value if applicable"
          }
        }
      }
    },
    "protection_rules_checked": {
      "type": "object",
      "properties": {
        "DR/backup_protection_tag": {
          "type": "boolean"
        },
        "DR/backup_protection_semantic": {
          "type": "boolean"
        }
      },
      "description": "Protection rule check results (keys match known rule names)"
    },
    "data_quality": {
      "type": "object",
      "required": ["valid_dimensions", "unreliable_dimensions", "overall_confidence"],
      "properties": {
        "valid_dimensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Dimensions with reliability >= 0.7"
        },
        "unreliable_dimensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Dimensions with reliability < 0.7 or missing data"
        },
        "overall_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Overall data quality confidence"
        }
      }
    },
    "risk_factors": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Notable risk factors for this resource"
    },
    "suggested_verification": {
      "type": "object",
      "required": [
        "verification_type",
        "methods",
        "estimated_effort_hours",
        "escalation_required",
        "precautions"
      ],
      "properties": {
        "verification_type": {
          "type": "string",
          "enum": [
            "api_only",
            "ssh_required",
            "manual_review",
            "owner_inquiry",
            "dependency_analysis"
          ],
          "description": "Type of verification needed"
        },
        "methods": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Specific verification methods"
        },
        "estimated_effort_hours": {
          "type": "number",
          "minimum": 0,
          "description": "Estimated verification effort in hours"
        },
        "escalation_required": {
          "type": "boolean",
          "description": "Whether escalation to owner/team is needed"
        },
        "precautions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Safety precautions before verification"
        }
      }
    }
  },
  "additionalProperties": false,
  "not": {
    "anyOf": [
      {"required": ["safe_to_delete"]},
      {"required": ["verdict"]},
      {"required": ["confidence"]},
      {"required": ["recommendation"]}
    ]
  }
}
