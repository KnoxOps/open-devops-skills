#!/usr/bin/env python3
"""Wrapper around agent-runbook that derives output path from directory convention.

Convention: plugins/<agent>/agent-runbooks/<skill-name>/runbook.yaml
Output:     plugins/<agent>/skills/<skill-name>/
"""

import os
import subprocess
import sys
from pathlib import Path


def main() -> None:
    if len(sys.argv) < 2:
        print("Usage: gen-skill <runbook.yaml> [--lang zh|en]", file=sys.stderr)
        sys.exit(1)

    runbook = Path(sys.argv[1]).resolve()
    parts = runbook.parts

    try:
        agent_runbooks_idx = parts.index("agent-runbooks")
    except ValueError:
        print("Error: runbook path must contain 'agent-runbooks' directory", file=sys.stderr)
        print("Expected: plugins/<agent>/agent-runbooks/<skill>/runbook.yaml", file=sys.stderr)
        sys.exit(1)

    if len(parts) < agent_runbooks_idx + 3:
        print("Error: expected plugins/<agent>/agent-runbooks/<skill>/runbook.yaml", file=sys.stderr)
        sys.exit(1)

    agent = parts[agent_runbooks_idx - 1]
    skill = parts[agent_runbooks_idx + 1]

    # Find the repo root (directory containing 'plugins')
    try:
        plugins_idx = parts.index("plugins")
        repo_root = Path(*parts[:plugins_idx])
    except ValueError:
        repo_root = runbook.parents[agent_runbooks_idx + 1]

    output = repo_root / "plugins" / agent / "skills" / skill

    rest = sys.argv[2:]

    # agent_runbook must be installed: pip install git+https://github.com/KnoxOps/agent-runbook.git
    cmd = [sys.executable, "-m", "agent_runbook", "generate", str(runbook), "-o", str(output), *rest]
    subprocess.run(cmd, check=True)

    # Copy prompts/ directory from runbook dir to output dir if it exists
    prompts_src = runbook.parent / "prompts"
    prompts_dst = output / "prompts"
    if prompts_src.is_dir():
        import shutil
        shutil.rmtree(prompts_dst, ignore_errors=True)
        shutil.copytree(prompts_src, prompts_dst)
        print(f"Copied prompts to: {prompts_dst}")

    # Post-process SKILL.md: replace relative prompt/reference paths with $PLUGINS paths
    skill_md = output / "SKILL.md"
    if skill_md.exists():
        content = skill_md.read_text()
        plugins_prefix = f"$PLUGINS/{agent}/skills/{skill}/"
        # Replace all backtick-quoted prompts/ paths
        content = content.replace("`prompts/", f"`{plugins_prefix}prompts/")
        skill_md.write_text(content)


if __name__ == "__main__":
    main()
