{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Observation Batch Summary Input",
  "description": "Phase 2 observation batch summary. Used as input to the decision handler merge step.",
  "type": "object",
  "required": ["observation_batch_id", "generated_at", "total_resources", "results"],
  "properties": {
    "observation_batch_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "total_resources": { "type": "integer" },
    "results": {
      "type": "object",
      "properties": {
        "passed": { "type": "integer" },
        "failed": { "type": "integer" },
        "uncertain": { "type": "integer" }
      }
    },
    "rollback_summary": {
      "type": "object",
      "properties": {
        "triggered": { "type": "integer" },
        "completed": { "type": "integer" },
        "failed": { "type": "integer" }
      }
    },
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "resource_id": { "type": "string" },
          "observation_result": { "type": "string" },
          "rollback_triggered": { "type": "boolean" }
        }
      }
    }
  }
}
